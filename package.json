{
  "name": "codex-switch",
  "version": "0.1.0",
  "description": "Manage multiple isolated Codex login profiles and switch between them safely.",
  "type": "module",
  "bin": {
    "codex-switch": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:tray": "dotnet build windows-tray/CodexSwitch.Tray.sln",
    "check": "tsc -p tsconfig.json --noEmit",
    "debug:attach-cdp": "node --import tsx scripts/attach-chrome-cdp.ts",
    "debug:login-flow": "node --import tsx scripts/inspect-login-flow.ts",
    "debug:login-flow:cdp": "node --import tsx scripts/inspect-login-flow-cdp.ts",
    "publish:tray": "powershell -ExecutionPolicy Bypass -File scripts/publish-windows-tray.ps1",
    "test": "vitest run",
    "test:tray": "dotnet test windows-tray/CodexSwitch.Tray.sln",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts"
  },
  "keywords": [
    "codex",
    "cli",
    "profile",
    "switcher"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "keytar": "^7.9.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
